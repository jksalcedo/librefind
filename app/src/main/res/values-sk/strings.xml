    <string name="help_app_name_title">Názov aplikácie</string>
    <string name="help_app_name_desc">Názov aplikácie ktorý je používateľom známy (napr. \"Signal\", \"Firefox\" alebo \"VLC\").</string>
    <string name="help_app_name_tip">Použiťe oficiálny názov zo stránky aplikácie alebo z obchodu.</string>
    <string name="help_package_name_title">Názov balíka</string>
    <string name="help_package_name_desc">Unikátny technický identifikátor aplikácie (napr. \"org.mozilla.firefox\"). Toto NIE JE názov aplikácie.</string>
    <string name="help_package_name_tip">Nájdite ju na F-Droid (na stránke aplikácie), na Play Store s URL: play.google.com/store/apps/details?id=&lt;package.name&gt; alebo na vašom zariadení: Nastavenia → Aplikácie → [Aplikácia] → Informácie o aplikácii.</string>
    <string name="help_description_title">Popis</string>
    <string name="help_description_desc">Krátky súhrn toho, čo aplikácia robí. 1 až 3 vety.</string>
    <string name="help_repo_url_title">URL repozitára</string>
    <string name="help_repo_url_desc">Link pre repozitár so zdrojovým kódom. Toto je potrebné na overenie, či je aplikácia skutočne open-source.</string>
    <string name="help_repo_url_tip">Hľadajte na stránke aplikácie, na zozname F-Droid alebo vyhľadajte \"&lt;názov&gt; source code\" na GitHub/GitLab/Codeberg.</string>
    <string name="help_fdroid_id_title">ID pre F-Droid</string>
    <string name="help_fdroid_id_desc">Názov balíka ako je uvedený na F-Droid. Väčšinou rovnaký ako názov balíka, ale niektoré aplikácie využívajú iné ID ako F-Droid.</string>
    <string name="help_fdroid_id_tip">Hľadajte na f-droid.org — ID je v URL adrese: f-droid.org/packages/&lt;fdroid.id&gt;/</string>
    <string name="help_license_title">Licencia</string>
    <string name="help_license_desc">Licencia pre otvorený zdrojový kód je uvedená nižšie (napr. GPL-3.0-only, GPL-3.0-or-later, MIT, Apache-2.0). Toto je potrebné pre návrh FOSS.</string>
    <string name="help_license_tip">Skontrolujte licenciu [LICENSE] alebo kopírovanie [COPYING] súboru v repozitári zdrojového kódu, alebo skontrolujte F-Droid.</string>
    <string name="help_target_apps_title">Cieľové uzavreté aplikácie</string>
    <string name="help_target_apps_desc">Uzavreté aplikácie ktoré môže táto FOSS aplikácia nahradiť. Napríklad Signal nahrádza WhatsApp/Telegram.</string>
    <string name="help_target_apps_tip">Vybrať zo zoznamu známych uzavretých aplikácii. Ak nie je uvedená, môźete ju navrhnúť ako novú uzavretú aplikáciu.</string>
