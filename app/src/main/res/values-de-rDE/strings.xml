    <!-- Submit Field Help -->
    <string name="help_app_name_title">App Name</string>
    <string name="help_app_name_desc">Der Anzeigename der App, unter dem Benutzer sie kennen (z.B. „Signal“, „Firefox“, „VLC“).</string>
    <string name="help_app_name_tip">Nutze den offiziellen Namen von der App-Website oder dem App-Store Eintrag.</string>
    <string name="help_package_name_title">Paketname</string>
    <string name="help_package_name_desc">Die eindeutige technische Kennung der App (z.B. „org.mozilla.firefox“). Das ist NICHT der Anzeigename.</string>
    <string name="help_package_name_tip">Finde sie auf F-Droid (gelistet auf der App-Seite) oder in der Play Store URL: play.google.com/store/apps/details?id=&lt;package.name&gt;. Auf deinem Gerät: Einstellungen → Apps → [App] → App Info.</string>
    <string name="help_description_title">Beschreibung</string>
    <string name="help_description_desc">Eine kurze Zusammenfassung der Funktion der App. Beschränke dich auf 1-3 Sätze.</string>
    <string name="help_repo_url_title">Repository URL</string>
    <string name="help_repo_url_desc">Der Link zu dem öffentlichen Quellcode-Repository der App. Dieser wird benötigt um zu verifizieren, dass die App wirklich quelloffen ist.</string>
    <string name="help_repo_url_tip">Suche danach auf der App-Website, dem F-Droid Eintrag oder suche nach „&lt;app name&gt; source code“ auf GitHub/GitLab/Codeberg.</string>
    <string name="help_fdroid_id_title">F-Droid ID</string>
    <string name="help_fdroid_id_desc">Der Paketname wie auf F-Droid aufgeführt. Normalerweise gleich dem Paketnamen, aber manche Apps nutzen eine andere ID für F-Droid-Builds.</string>
    <string name="help_fdroid_id_tip">Finde sie auf f-droid.org — die ID ist in der URL: f-droid.org/packages/&lt;fdroid.id&gt;/</string>
    <string name="help_license_title">Lizenz</string>
    <string name="help_license_desc">Die Open-Source-Lizenz, unter welcher die App veröffentlicht wird (z.B. GPL-3.0-only, GPL-3.0-or-later, MIT, Apache-2.0). Diese wird benötigt für FOSS-Einreichungen.</string>
    <string name="help_license_tip">Prüfe die LICENSE oder COPYING Datei in dem Quellcode-Repository der App oder schaue auf den F-Droid-Eintrag.</string>
    <string name="help_target_apps_title">Ziel-Proprietäre Apps</string>
    <string name="help_target_apps_desc">Die proprietären Apps, die diese FOSS-App ersetzen kann. Zum Beispiel: Signal ersetzt WhatsApp/Telegram.</string>
    <string name="help_target_apps_tip">Wähle von der Liste bekannter proprietären Apps. Falls das Ziel nicht gelistet ist, kannst du es zuerst vorschlagen als ein neues proprietäres Ziel.</string>
    <string name="help_search_alternatives_title">Suche Alternativen</string>
    <string name="help_search_alternatives_desc">Suche nach existierenden FOSS-Alternativen in unserer Datenbank um eine Verknüpfung zu dieser proprietären App herzustellen.</string>
