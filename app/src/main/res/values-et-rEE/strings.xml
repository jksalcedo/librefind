    <!-- Submit Field Help -->
    <string name="help_app_name_title">Rakenduse nimi</string>
    <string name="help_app_name_desc">Rakenduse nimi mida selle kasutajad tunnevad (nt. \"Signal\", \"Firefox\", \"VLC\").</string>
    <string name="help_app_name_tip">Kasutage ametlik nimi rakenduse veebileheküljelt või poe nimekirjast.</string>
    <string name="help_package_name_title">Pakendi nimi</string>
    <string name="help_package_name_desc">Rakenduse unikaalne tehniline tunnus (nt „org.mozilla.firefox”). See EI OLE kuvatav nimi.</string>
    <string name="help_package_name_tip">Leidke see F-Droidist (loetletud rakenduse lehel) või Play Store\'ist URL: play.google.com/store/apps/details?id=&lt;package.name&gt;. Teie seadmes: Seaded → Rakendused → [Rakendus] → Rakenduse üksikasjad.</string>
    <string name="help_description_title">Kirjeldus</string>
    <string name="help_description_desc">Lühike kokkuvõte sellest, mida rakendus teeb. u. 1-3 lauset.</string>
    <string name="help_repo_url_title">Repositooriumi link</string>
    <string name="help_repo_url_desc">Link rakenduse avatud lähtekoodi repositooriumile. See on vajalik selleks, et kinnitada rakenduse lähtekoodi avalikust.</string>
    <string name="help_repo_url_tip">Otsi rakenduse tunnust veebileheküljelt, F-Droidi nimekirjast või otsi GitHubis/GitLabis/Codebergis „&lt;rakenduse nimi&gt; lähtekood”.</string>
    <string name="help_fdroid_id_title">F-Droid ID</string>
    <string name="help_fdroid_id_desc">Rakenduse tunnuse nagu see on F-Droidi nimekirjas. Tavaliselt tunnus on sama, aga mõndadel rakendustel on erinevad tunnused F-Droidi versiooni jaoks.</string>
    <string name="help_fdroid_id_tip">Leia seda leheküljelt f-droid.org — ID on lingis: f-droid.org/packages/&lt;fdroid.id&gt;/</string>
    <string name="help_license_title">Litsents</string>
    <string name="help_license_desc">Rakenduse avatud lähtekoodi litsents (nt. ainult GPL-3.0, GPL-3.0 või uuem, MIT, Apache-2.0). See on vajalik vabarakenduse esitamiseks.</string>
    <string name="help_license_tip">Kontrollige rakenduse lähtekoodi repositooriumis olevat LICENSE- või COPYING-faili või vaadake F-Droidi nimekirja.</string>
    <string name="help_target_apps_title">Omandilised sihtrakendused</string>
    <string name="help_target_apps_desc">Omandiline rakendus mida see vabarakendus asendab. Nt. Signal asendab Whatsapp/Telegram.</string>
    <string name="help_target_apps_tip">Valige tuntud omandiliste rakenduste nimekirjast. Kui sihtrakendust ei leidu, te võite ennem esitada seda nagu uus omandiline sihtrakendus.</string>
    <string name="help_search_alternatives_title">Otsige alternatiive</string>
    <string name="help_search_alternatives_desc">Otisige olevate vabarakenduslike alternatiive meie andmebaasist, et siduda seda omandilisega rakendusega.</string>
