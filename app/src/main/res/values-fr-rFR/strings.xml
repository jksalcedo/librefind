    <!-- Submit Field Help -->
    <string name="help_app_name_title">Nom de l\'application</string>
    <string name="help_app_name_desc">Le nom d\'affichage de l\'application tel que les utilisateurs le connaissent (par exemple « Signal », « Firefox », « VLC »).</string>
    <string name="help_app_name_tip">Utilisez le nom officiel figurant sur le site web de l\'application ou dans la fiche de l\'application sur la boutique en ligne.</string>
    <string name="help_package_name_title">Nom du paquet</string>
    <string name="help_package_name_desc">L\'identifiant unique de l\'app (ex. \"org.mozilla.firefox\"). Ce n\'est PAS le nom d\'affichage.</string>
    <string name="help_package_name_tip">Trouvez-le sur F-Droid (indiqué sur la page de l\'app), ou dans l\'URL Play Store: play.google.com/store/apps/details?id=&lt;package.name&gt;. Sur votre appareil : Paramètres → Applications → [Application] → Infos sur l\'application.</string>
    <string name="help_description_title">Description</string>
    <string name="help_description_desc">Un bref résumé de ce que l\'application fait. Limitez-vous à 1 à 3 phrases.</string>
    <string name="help_repo_url_title">URL du dépôt</string>
    <string name="help_repo_url_desc">Le lien vers le dépôt public du code source de l\'application. Ceci est requis pour vérifier que l\'application est réellement open source.</string>
    <string name="help_repo_url_tip">Cherchez-le sur le site de l\'app, sur F-Droid, ou cherchez \"&lt;app name&gt; code source\" sur GitHub/GitLab/Codeberg.</string>
    <string name="help_fdroid_id_title">ID F-Droid</string>
    <string name="help_fdroid_id_desc">Le nom du paquet tel qu\'il apparaît sur F-Droid. Il correspond généralement au nom du paquet, mais certaines applications utilisent un identifiant différent pour les versions F-Droid.</string>
    <string name="help_fdroid_id_tip">Vous le trouverez sur f-droid.org — l\'identifiant figure dans l\'URL : f-droid.org/packages/&lt;fdroid.id&gt;/</string>
    <string name="help_license_title">Licence</string>
    <string name="help_license_desc">La licence open source sous laquelle l\'app est publiée (ex. GPL-3.0-only, GPL-3.0-or-later, MIT, Apache-2.0). Ceci est requis pour les soumissions FOSS.</string>
    <string name="help_license_tip">Vérifiez le fichier LICENSE ou COPYING dans le dépôt du code source de l\'app, ou consultez la page F‑Droid.</string>
    <string name="help_target_apps_title">Target Proprietary Apps</string>
    <string name="help_target_apps_desc">L\'app propriétaire que cette app FOSS peut remplacer. Par exemple, Signal remplace WhatsApp/Telegram.</string>
    <string name="help_target_apps_tip">Select from the list of known proprietary apps. If the target isn\'t listed, you can suggest it as a new proprietary target first.</string>
    <string name="help_search_alternatives_title">Chercher une alternative</string>
    <string name="help_search_alternatives_desc">Recherchez des alternatives FOSS existantes dans notre base de données pour les associer à cette app propriétaire.</string>
