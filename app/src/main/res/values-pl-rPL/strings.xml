    <!-- Submit Field Help -->
    <string name="help_app_name_title">Nazwa aplikacji</string>
    <string name="help_app_name_desc">Wyświetlana nazwa aplikacji, jaką znają użytkownicy (np.: \"Signal\", \"Firefox\", \"VLC\").</string>
    <string name="help_app_name_tip">Użyj oficjalnej nazwy ze strony aplikacji lub sklepu.</string>
    <string name="help_package_name_title">Nazwa pakietu</string>
    <string name="help_package_name_desc">Unikalny identyfikator techniczny aplikacji (np.: \"org.mozilla.firefox\"). To NIE JEST nazwa wyświetlana.</string>
    <string name="help_package_name_tip">Znajdź to na F-droid (na stronie aplikacji), albo w Sklepie Play po URL: play.google.com/store/apps/details?id=&lt;package.name&gt;. Na urządzeniu: Ustawienia → Aplikacje → [Aplikacja] → Informacje o aplikacji.</string>
    <string name="help_description_title">Opis</string>
    <string name="help_description_desc">Krótkie podsumowanie co robi aplikacja. Zmieść się w 1-3 zdaniach.</string>
    <string name="help_repo_url_title">URL repozytorium</string>
    <string name="help_repo_url_desc">Link do repozytorium z publicznym kodem źródłowym aplikacji. Wymagane do sprawdzenia, czy aplikacja jest naprawdę otwartoźródłowa.</string>
    <string name="help_repo_url_tip">Poszukaj na stronie aplikacji, liście F-droid, albo po \"&lt;nazwa aplikacji&gt; source code\" na GitHub/GitLab/Codeberg.</string>
    <string name="help_fdroid_id_title">ID F-droid</string>
    <string name="help_fdroid_id_desc">Nazwa pakietu jak na F-droid. Zazwyczaj taka sama jak nazwa pakietu, ale niektóre aplikacje używają innego ID dla zbudowanych przez F-droid.</string>
    <string name="help_fdroid_id_tip">Znajdź na f-droid.org - ID jest w URL: f-droid.org/packages/&lt;fdroid.id&gt;/</string>
    <string name="help_license_title">Licencja</string>
    <string name="help_license_desc">Licencja otwartoźródłowa, pod którą została wydana aplikacja (np.: GPL-3.0-only, GPL-3.0-or-later, MIT, Apache-2.0). To jest wymagane dla zgłoszonych aplikacji FOSS.</string>
    <string name="help_license_tip">Sprawdź plik LICENCJA albo KOPIOWANIE w repo z kodem źródłowym aplikacji, albo sprawdź na F-droid.</string>
    <string name="help_target_apps_title">Docelowe aplikacje własnościowe</string>
    <string name="help_target_apps_desc">Aplikacje własnościowe, które ta aplikacja FOSS może zastąpić. Np.: Signal zastępuje WhatsApp/Telegram.</string>
    <string name="help_target_apps_tip">Wybierz z listy znanych aplikacji własnościowych. Jeżeli brak docelowej, możesz zasugerować jako nową własnościową.</string>
    <string name="help_search_alternatives_title">Przeszukaj alternatywy</string>
    <string name="help_search_alternatives_desc">Szukaj istniejących w bazie alternatyw FOSS, żeby połączyć do tej aplikacji własnościowej.</string>
